    "/fhir/ValueSet/cnp": {
      "get": {
        "summary": "Validate CNP",
        "description": "Validate a Romanian Personal Numerical Code (CNP) and return detailed information",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "CNP to validate",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {

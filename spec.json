            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "cnp": {
                      "type": "string"
                    },
                    "valid": {
                      "type": "boolean"
                    },
                    "gender": {
                      "type": "string"
                    },
                    "birth_date": {
                      "type": "string"
                    },
                    "county_code": {
                      "type": "integer"
                    },
                    "county_name": {
                      "type": "string"
                    },
                    "serial": {
                      "type": "string"
                    },
                    "control_digit": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {

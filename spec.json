                        "description": "CNP validation result with detailed information",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "cnp": {
                                            "type": "string"
                                        },
                                        "valid": {
                                            "type": "boolean"
                                        },
                                        "gender": {

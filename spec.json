{
  "openapi": "3.0.0",
  "info": {
    "title": "HippoBridge FHIR API",
    "description": "FHIR-compatible API for accessing patient data from the Hipocrate medical system",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:44660",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Web interface",
        "description": "Returns the web interface for patient analysis with CNP input form",
        "responses": {
          "200": {
            "description": "HTML web interface"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/fhir/Metadata": {
      "get": {
        "summary": "FHIR Capability Statement",
        "description": "Returns the FHIR capability statement for this server",
        "responses": {
          "200": {
            "description": "FHIR CapabilityStatement resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resourceType": {
                      "type": "string",
                      "example": "CapabilityStatement"
                    },
                    "id": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "experimental": {
                      "type": "boolean"
                    },
                    "date": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "publisher": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "kind": {
                      "type": "string"
                    },
                    "software": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        }
                      }
                    },
                    "fhirVersion": {
                      "type": "string"
                    },
                    "format": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "rest": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "mode": {
                            "type": "string"
                          },
                          "resource": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "type": {
                                  "type": "string"
                                },
                                "interaction": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "code": {
                                        "type": "string"
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fhir/spec": {
      "get": {
        "summary": "OpenAPI Specification",
        "description": "Returns this OpenAPI specification in JSON format",
        "responses": {
          "200": {
            "description": "OpenAPI specification in JSON format"
          }
        }
      }
    },
    "/fhir/md2html": {
      "post": {
        "summary": "Convert markdown to HTML",
        "description": "Convert simple markdown text to basic HTML for display in web interface",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Markdown text to convert"
                  }
                },
                "required": [
                  "text"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "HTML conversion result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "html": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid JSON data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Invalid JSON data"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Conversion error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fhir/Patient": {
      "get": {
        "summary": "Search for patients",
        "description": "Search for patients by name, CNP, patient code, or partial CNP. Returns FHIR Patient resources or Bundle.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search term (patient name, CNP, patient code, or partial CNP ending with *)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Single Patient or Bundle of Patients",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "resourceType": { "type": "string", "example": "Patient" }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "resourceType": { "type": "string", "example": "Bundle" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Missing search term",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Search term is required"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Authentication required"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "No patients found",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resourceType": {
                      "type": "string",
                      "example": "OperationOutcome"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fhir/Patient/{id}": {
      "get": {
        "summary": "Get patient information",
        "description": "Retrieve detailed patient information by ID, CNP, or partial CNP as FHIR Patient resource",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Patient ID, 13-digit CNP, or partial CNP with asterisk (*)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patient information as FHIR Patient resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resourceType": {
                      "type": "string",
                      "example": "Patient"
                    },
                    "id": {
                      "type": "string"
                    },
                    "identifier": {
                      "type": "array"
                    },
                    "name": {
                      "type": "array"
                    },
                    "gender": {
                      "type": "string"
                    },
                    "birthDate": {
                      "type": "string"
                    },
                    "extension": {
                      "type": "array"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing patient ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Patient ID is required"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Authentication required"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Patient not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Patient not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fhir/ServiceRequest": {
      "get": {
        "summary": "Get patient service requests",
        "description": "Retrieve all service requests for a patient as FHIR ServiceRequest resources with optional filtering by type, region and datetime",
        "parameters": [
          {
            "name": "patient",
            "in": "query",
            "required": true,
            "description": "Patient ID, 13-digit CNP, or partial CNP with asterisk (*)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "Analysis type to filter by (e.g., radio, ct, irm, eco, lab, lac, lii, rads, apa)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "region",
            "in": "query",
            "required": false,
            "description": "Anatomical region to filter by",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dt",
            "in": "query",
            "required": false,
            "description": "Target date/time in ISO format. Filters requests to those closest to this timestamp using a binary-narrowing window (starts at ±24 h, halves on each ambiguous attempt until a single match is found).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patient service requests as FHIR Bundle of ServiceRequest resources",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resourceType": {
                      "type": "string",
                      "example": "Bundle"
                    },
                    "entry": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "resource": {
                            "type": "object",
                            "properties": {
                              "resourceType": {
                                "type": "string",
                                "example": "ServiceRequest"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing patient ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Patient ID is required"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Authentication required"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fhir/ServiceRequest/{id}": {
      "get": {
        "summary": "Get a single service request",
        "description": "Retrieve a single service request by ID. Without ?type, scrapes buletinRecoltari.asp (collection sheet: patient demographics, ordered procedures, physician, section). With ?type=cerere, scrapes cerere.asp (full request edit form: adds priority, clinical indication, justification, diagnosis, payment type, and numeric patient ID — returns 403 if the authenticated user lacks access to the lab).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ServiceRequest ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "Source hint: omit for buletinRecoltari (default), or pass 'cerere' for the full request edit form",
            "schema": {
              "type": "string",
              "enum": ["cerere"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ServiceRequest as FHIR ServiceRequest resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resourceType": {
                      "type": "string",
                      "example": "ServiceRequest"
                    },
                    "id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "intent": {
                      "type": "string"
                    },
                    "priority": {
                      "type": "string"
                    },
                    "code": {
                      "type": "object"
                    },
                    "subject": {
                      "type": "object"
                    },
                    "authoredOn": {
                      "type": "string"
                    },
                    "bodySite": {
                      "type": "array"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing service request ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Service request ID is required"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Authentication required"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

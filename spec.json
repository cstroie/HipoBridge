    "/fhir/Schedule": {
      "get": {
        "summary": "Get imaging/lab worklist",
        "description": "Returns a searchset Bundle of ServiceRequest resources from the Hipocrate schedule page. Lab and patient filters are passed as native Hipocrate URL params; section is filtered server-side by name.",
        "parameters": [
          {"name": "start_date", "in": "query", "required": false, "description": "Range start (YYYY-MM-DD, default today)", "schema": {"type": "string", "format": "date"}},
          {"name": "end_date", "in": "query", "required": false, "description": "Range end (YYYY-MM-DD, default same as start_date)", "schema": {"type": "string", "format": "date"}},
          {"name": "lab_id", "in": "query", "required": false, "description": "Hipocrate lab ID (26=CT, 28=Eco, 32=IRM, 49=Radiografie, 35=Rad.Interventionala, 50=Radioscopii)", "schema": {"type": "integer"}},
          {"name": "patient_text", "in": "query", "required": false, "description": "Patient name free-text search (PARA_TextCautare)", "schema": {"type": "string"}},
          {"name": "section_name", "in": "query", "required": false, "description": "Exact section name — server-side filter", "schema": {"type": "string"}},
          {"name": "refresh", "in": "query", "required": false, "description": "Set to 1 to bypass the 30-minute LRU cache", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {
            "description": "searchset Bundle of ServiceRequest resources",
            "content": {
              "application/fhir+json": {
                "schema": {"type": "object", "properties": {"resourceType": {"type": "string", "example": "Bundle"}, "type": {"type": "string", "example": "searchset"}, "total": {"type": "integer"}, "entry": {"type": "array"}}}
              }
            }
          },
          "401": {"description": "Authentication required"}
        }
      }
    },
    "/api/schedule": {
      "get": {
        "summary": "Get schedule (raw JSON)",
        "description": "Same as /fhir/Schedule but returns raw HippoData JSON. Accepts the same query parameters.",
        "parameters": [
          {"name": "start_date", "in": "query", "required": false, "schema": {"type": "string"}},
          {"name": "end_date", "in": "query", "required": false, "schema": {"type": "string"}},
          {"name": "lab_id", "in": "query", "required": false, "schema": {"type": "integer"}},
          {"name": "patient_text", "in": "query", "required": false, "schema": {"type": "string"}},
          {"name": "section_name", "in": "query", "required": false, "schema": {"type": "string"}},
          {"name": "refresh", "in": "query", "required": false, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Raw schedule data"},
          "401": {"description": "Authentication required"}
        }
      }
    },
    "/api/request/{id}/patient": {
      "get": {
        "summary": "Full request details from cerere.asp",
        "description": "Scrapes cerere.asp (request edit form) and returns patient name, CNP, demographics, numeric patient ID, request date/time, priority, payment type, physician, section, diagnosis, clinical indication, justification, request code, laboratory name, and exam list. Returns an access-denied error for labs the authenticated user cannot view; use /api/request/{id} (buletinRecoltari) as fallback for patient demographics in that case. Supports ?debug=page.",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "description": "Request ID", "schema": {"type": "string"}},
          {"name": "debug", "in": "query", "required": false, "description": "Pass 'page' to get raw Hipocrate HTML", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Full request and patient details as HippoData JSON"},
          "403": {"description": "Access denied to this lab"},
          "401": {"description": "Authentication required"}
        }
      }
    },
    "/api/checkin/{id}": {
      "get": {
        "summary": "Get admission record (checkin)",
        "description": "Scrapes checkin.asp and returns patient identity, presentation details, diagnoses, ward transfers, and clinical exam as raw JSON.",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "description": "Admission ID", "schema": {"type": "string"}},
          {"name": "debug", "in": "query", "required": false, "description": "Pass 'page' to get raw Hipocrate HTML", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Admission record as HippoData JSON"},
          "404": {"description": "Admission not found"},
          "401": {"description": "Authentication required"}
        }
      }
    },
    "/api/checkup/{id}": {
      "get": {
        "summary": "Get emergency consultation (checkup)",
        "description": "Scrapes checkup.asp and returns patient identity, consultation details, ICD-10 codes, diagnoses, discharge status, and clinical exam as raw JSON.",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "description": "Consultation UID", "schema": {"type": "string"}},
          {"name": "debug", "in": "query", "required": false, "description": "Pass 'page' to get raw Hipocrate HTML", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Consultation record as HippoData JSON"},
          "404": {"description": "Consultation not found"},
          "401": {"description": "Authentication required"}
        }
      }
    },
    "/api/debug": {
      "get": {
        "summary": "Raw Hipocrate HTML passthrough",
        "description": "Fetch any Hipocrate path and return the raw HTML. Useful for inspecting pages before writing a parser.",
        "parameters": [
          {"name": "path", "in": "query", "required": true, "description": "Hipocrate path to fetch (e.g. /Pacient/history.asp?pacid=123)", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Raw HTML from Hipocrate"},
          "400": {"description": "Missing path parameter"},
          "401": {"description": "Authentication required"}
        }
      }
    },
    "/fhir/CodeSystem/analysis-types": {
      "get": {
        "summary": "Get analysis types",
        "description": "Retrieve the FHIR CodeSystem resource defining the analysis types used in the hospital system",
        "responses": {
          "200": {
            "description": "Analysis types as FHIR CodeSystem resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resourceType": {
                      "type": "string",
                      "example": "CodeSystem"
                    },
                    "id": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "experimental": {
                      "type": "boolean"
                    },
                    "date": {
                      "type": "string"
                    },
                    "publisher": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "caseSensitive": {
                      "type": "boolean"
                    },
                    "content": {
                      "type": "string"
                    },
                    "concept": {
                      "type": "array"
                    }
                  }
                }
              }
            }
          }
